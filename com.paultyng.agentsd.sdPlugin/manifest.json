{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "UUID": "com.paultyng.agentsd.session",
      "Name": "Session",
      "Icon": "imgs/session",
      "Tooltip": "Shows active Claude Code session. Press to cycle.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/session", "ShowTitle": true, "TitleAlignment": "bottom", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.mode",
      "Name": "Mode",
      "Icon": "imgs/mode",
      "Tooltip": "Shows current permission mode.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/mode", "ShowTitle": true, "TitleAlignment": "middle", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.status",
      "Name": "Status",
      "Icon": "imgs/status",
      "Tooltip": "Shows current session state and active tool.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/status", "ShowTitle": true, "TitleAlignment": "middle", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.focus",
      "Name": "Focus",
      "Icon": "imgs/focus",
      "Tooltip": "Bring Ghostty or Claude Desktop to front.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/focus", "ShowTitle": true, "TitleAlignment": "bottom", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.stop",
      "Name": "Stop",
      "Icon": "imgs/stop",
      "Tooltip": "Send interrupt to running Claude Code session.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/stop", "ShowTitle": true, "TitleAlignment": "bottom", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.approve",
      "Name": "Approve",
      "Icon": "imgs/approve",
      "Tooltip": "Approve pending permission request.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/approve", "ShowTitle": true, "TitleAlignment": "bottom", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.always-allow",
      "Name": "Always Allow",
      "Icon": "imgs/approve",
      "Tooltip": "Approve and always allow this tool for the session.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/approve", "ShowTitle": true, "TitleAlignment": "bottom", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.deny",
      "Name": "Deny",
      "Icon": "imgs/deny",
      "Tooltip": "Deny pending permission request.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/deny", "ShowTitle": true, "TitleAlignment": "bottom", "TitleColor": "#FFFFFF" }]
    },
    {
      "UUID": "com.paultyng.agentsd.session-dial",
      "Name": "Session Selector",
      "Icon": "imgs/session",
      "Tooltip": "Rotate to cycle sessions.",
      "Controllers": ["Encoder"],
      "States": [{ "Image": "imgs/session", "ShowTitle": true, "TitleAlignment": "middle", "TitleColor": "#FFFFFF" }],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Cycle sessions",
          "Push": "Select session"
        }
      }
    }
  ],
  "Author": "Paul Tyng",
  "Category": "Claude Code",
  "CategoryIcon": "imgs/plugin",
  "CodePath": "bin/plugin.js",
  "Description": "Stream Deck companion for Claude Code sessions. Shows session state, tools, and enables permission approval directly from hardware buttons.",
  "Icon": "imgs/plugin",
  "Name": "agentsd",
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "OS": [
    { "Platform": "mac", "MinimumVersion": "13" }
  ],
  "UUID": "com.paultyng.agentsd",
  "Version": "0.1.0.0",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.6"
  }
}
